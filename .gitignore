# Python venv for the C extractor toolchain (tree-sitter; ADR-001) — provisioned per-environment
.venv/

# Python bytecode cache
__pycache__/
*.pyc

# macOS
.DS_Store

# scratch / throwaway probes
scratch_*.py

# Run-workspace cloned repos: reproducible by re-cloning the source (clone.py); not source state
runs/*/repo/
runs/*/.clone_descriptor.json

# Generate backend runs index (TASK-050): a run_id→working_path pointer log rebuilt per env
runs/.runs_index.jsonl

# Frontend (TASK-051) build/install artifacts — reproducible from package.json
app/frontend/node_modules/
app/frontend/dist/
# cred.env: a secret token — NEVER commit
cred.env

# NOTE: registry_repo/ is intentionally NOT ignored — it travels to the VDI as the push-ready
# registry tree. It is a generated copy of core/ + overlays/ + docs; after ANY change under
# those, refresh it with `python core/scripts/publish_registry.py --stage registry_repo --force`
# (the §10-gated rebuild) before committing, or it goes stale.
