# Python venv for the C extractor toolchain (tree-sitter; ADR-001) — provisioned per-environment
.venv/

# Python bytecode cache
__pycache__/
*.pyc

# macOS
.DS_Store

# scratch / throwaway probes
scratch_*.py

# Run-workspace cloned repos: reproducible by re-cloning the source (clone.py); not source state
runs/*/repo/
runs/*/.clone_descriptor.json
