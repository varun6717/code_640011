{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decisions.schema.json",
  "title": "decisions.jsonl — gate + flag audit record (TECH_SPEC §3.6, NFR-03)",
  "description": "One object per line; append-only. Every gate and flag decision: who, when, outcome, rationale. Four record kinds keyed by `kind`. Field shapes for reonboard_flag / vocab_gap_flag match the writers in core/scripts/decisions.py. Records decisions only — never artifact content (FR-XS-05).",
  "type": "object",
  "required": ["ts", "kind"],
  "additionalProperties": false,
  "properties": {
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "kind": { "enum": ["gate", "flag", "reonboard_flag", "vocab_gap_flag"] },
    "actor": { "type": "string" },
    "gate": { "enum": ["G1", "G2", "G3"] },
    "outcome": { "enum": ["accept", "reopen"] },
    "version": { "type": "integer", "minimum": 1 },
    "flag_type": { "type": "string" },
    "area": { "type": "string" },
    "option": { "type": "string" },
    "severity": { "enum": ["material", "advisory"] },
    "rationale": { "type": "string" },
    "language": { "type": "string" },
    "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "floor": { "type": "number", "minimum": 0, "maximum": 1 },
    "unresolved_patterns": { "type": "array", "items": { "type": "string" } },
    "arm": { "enum": ["code", "docs"] },
    "concept": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "untagged_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "decision": { "enum": ["pending", "amend-vocab", "accept-as-is", "re-onboard"] }
  },
  "oneOf": [
    { "properties": { "kind": { "const": "gate" } },
      "required": ["gate", "outcome", "actor", "version"] },
    { "properties": { "kind": { "const": "flag" } },
      "required": ["flag_type", "option", "severity", "rationale"] },
    { "properties": { "kind": { "const": "reonboard_flag" } },
      "required": ["language", "coverage", "floor", "decision", "actor"] },
    { "allOf": [
        { "properties": { "kind": { "const": "vocab_gap_flag" } },
          "required": ["arm", "decision", "actor"] },
        { "oneOf": [
            { "required": ["concept", "evidence"] },
            { "required": ["untagged_ratio", "threshold"] }
        ] }
    ] }
  ]
}
