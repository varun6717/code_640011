{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "telemetry.schema.json",
  "title": "telemetry.jsonl event record (TECH_SPEC §3.4 envelope + §8.1 payloads)",
  "description": "One object per line of ledger/telemetry.jsonl. Common envelope on every event (ts, run_id, domain, tool, event); event-specific payload by `event`. metrics_scan.py (§8.2) derives every metric from these rows — no metric is hand-entered. NOTE: the ledger records THAT things happened, never artifact CONTENT (FR-XS-05).",
  "type": "object",
  "required": ["ts", "run_id", "domain", "tool", "event"],
  "additionalProperties": false,
  "properties": {
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "run_id": { "type": "string" },
    "domain": { "type": "string" },
    "tool": { "enum": ["claude", "copilot"] },
    "event": {
      "enum": ["run_started", "stage_started", "stage_completed", "model_call",
               "validation", "gate_decision", "flag_decision", "jira_push", "error"]
    },
    "stage": { "$ref": "#/$defs/stage" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "path": { "type": "string" },
    "registry_sha": { "type": "string" },
    "model": { "type": "string" },
    "tokens_in": { "type": "integer", "minimum": 0 },
    "tokens_out": { "type": "integer", "minimum": 0 },
    "cost_usd": { "type": "number", "minimum": 0 },
    "artifact": { "enum": ["brd", "frd", "jira"] },
    "score": { "type": "number" },
    "gate": { "enum": ["G1", "G2", "G3"] },
    "outcome": { "enum": ["accept", "reopen"] },
    "actor": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "flag_type": { "type": "string" },
    "option": { "type": "string" },
    "severity": { "enum": ["material", "advisory"] },
    "epics": { "type": "integer", "minimum": 0 },
    "success": { "type": "boolean" },
    "partial": { "type": "boolean" },
    "kind": { "type": "string" },
    "message": { "type": "string" }
  },
  "oneOf": [
    { "properties": { "event": { "const": "run_started" } },   "required": ["path", "registry_sha"] },
    { "properties": { "event": { "const": "stage_started" } },  "required": ["stage"] },
    { "properties": { "event": { "const": "stage_completed" } },"required": ["stage", "duration_ms"] },
    { "properties": { "event": { "const": "model_call" } },     "required": ["stage", "model", "tokens_in", "tokens_out", "cost_usd"] },
    { "properties": { "event": { "const": "validation" } },     "required": ["artifact", "score"] },
    { "properties": { "event": { "const": "gate_decision" } },  "required": ["gate", "outcome", "actor", "version"] },
    { "properties": { "event": { "const": "flag_decision" } },  "required": ["flag_type", "option", "severity"] },
    { "properties": { "event": { "const": "jira_push" } },      "required": ["epics", "success", "partial"] },
    { "properties": { "event": { "const": "error" } },          "required": ["stage", "kind", "message"] }
  ],
  "$defs": {
    "stage": {
      "enum": ["ingest", "code_map", "brd_authoring", "code_impact",
               "frd_authoring", "jira_authoring", "jira_push"]
    }
  }
}
